# Copy this file to .env, fill in real values, and keep .env out of git.
# `scripts/build_dpo_pairs.py` auto-loads .env by default; override with DPO_ENV_FILE=/path/to/file.

# OpenAI-compatible multimodal judge API. Do not put real secrets in git.
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace-with-your-api-key
DPO_JUDGE_MODEL=gpt-5.4-mini
DPO_REFINE_MODEL=gpt-5.5
DPO_ENABLE_REFINE=0

# Data preparation defaults.
DPO_ANSWERS_PATH=data/raw/answers.jsonl
DPO_OUTPUT_PATH=data/processed/qwen2_5_vl_dpo_local_1000.json
DPO_AUDIT_PATH=data/audit/qwen2_5_vl_dpo_local_1000.audit.jsonl
DPO_MAX_ACCEPTED=1000
DPO_MAX_QUESTIONS=3000
DPO_CONFIDENCE_THRESHOLD=0.70
DPO_REFINE_THRESHOLD=0.78
DPO_MIN_SCORE_GAP=1.0
DPO_SEED=0
DPO_JUDGE_MODE=api
DPO_REQUEST_TIMEOUT=120
DPO_MAX_RETRIES=3
DPO_WORKERS=4
DPO_MAX_IMAGE_SIDE=1024
DPO_IMAGE_JPEG_QUALITY=85

# LLaMA-Factory integration.
LLAMAFACTORY_DIR=LlamaFactory
LLAMAFACTORY_DATASET_NAME=qwen2_5_vl_dpo_local_1000
LLAMAFACTORY_DATASET_FILE=qwen2_5_vl_dpo_local_1000.json
LLAMAFACTORY_IMAGE_SOURCE=images
LORA_ADAPTER_DIR=LlamaFactory/saves/qwen2_5_vl_3b_lora_dpo_local
LORA_FIXED_DIR=LlamaFactory/saves/qwen2_5_vl_3b_lora_dpo_local_fixed

# AMBER evaluation wrappers.
MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
BASE_OUTPUT_NAME=amber_base_local
LORA_OUTPUT_NAME=amber_lora_local
GPU_LIST=0
